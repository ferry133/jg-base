---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: first-nfs-subdir-external-provisioner
  namespace: storage
spec:
  interval: 15m
  timeout: 5m
  chart:
    spec:
      chart: nfs-subdir-external-provisioner
      sourceRef:
        kind: HelmRepository
        name: nfs-provisioner
        namespace: storage
      interval: 5m
  values:
    storageClass:
      name: sc-nas
      provisionerName: "k8s-sigs.io/first-nfs-subdir-external-provisioner"
      pathPattern: "jg-$${.PVC.namespace}-$${.PVC.name}"
    nfs:
      server: "#{ nas_server }#"
      path: "#{ nas_path }#"
